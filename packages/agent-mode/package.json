{
  "name": "@agnost/agent-mode",
  "version": "0.1.0",
  "description": "Zero-config analytics integration for AI agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    },
    "./vercel": {
      "import": { "types": "./dist/frameworks/vercel.d.mts", "default": "./dist/frameworks/vercel.mjs" },
      "require": { "types": "./dist/frameworks/vercel.d.ts", "default": "./dist/frameworks/vercel.js" }
    },
    "./openai": {
      "import": { "types": "./dist/frameworks/openai.d.mts", "default": "./dist/frameworks/openai.mjs" },
      "require": { "types": "./dist/frameworks/openai.d.ts", "default": "./dist/frameworks/openai.js" }
    },
    "./mastra": {
      "import": { "types": "./dist/frameworks/mastra.d.mts", "default": "./dist/frameworks/mastra.mjs" },
      "require": { "types": "./dist/frameworks/mastra.d.ts", "default": "./dist/frameworks/mastra.js" }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "echo ok"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/resources": "^1.30.0",
    "@arizeai/openinference-core": "^1.0.3"
  },
  "peerDependencies": {
    "ai": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "openai": "^4.95.0",
    "@arizeai/openinference-instrumentation-openai": "^2.3.1",
    "@mastra/otel-exporter": "*"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "openai": { "optional": true },
    "@arizeai/openinference-instrumentation-openai": { "optional": true },
    "@mastra/otel-exporter": { "optional": true }
  },
  "devDependencies": {
    "@arizeai/openinference-instrumentation-openai": "^2.3.1",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "license": "MIT"
}
